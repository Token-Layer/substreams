# Copy to .env.shared.sink

# Base DB URL without schemaName query param; chain scripts append schemaName automatically.
DATABASE_URL_BASE="postgres://dev:insecure@localhost:5432/main?sslmode=disable"

# Provider credentials (optional aliases). Chain script auto-selects by endpoint domain.
PINAX_API_KEY=
PINAX_API_TOKEN=
STREAMINGFAST_API_KEY=
STREAMINGFAST_API_TOKEN=

# Optional common auth fallback (used directly by sink scripts if already set).
SUBSTREAMS_API_KEY=
SUBSTREAMS_API_TOKEN=
